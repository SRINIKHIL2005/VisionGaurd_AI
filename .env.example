# VisionGuard AI - Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== JWT Authentication =====
JWT_SECRET_KEY=your-super-secret-key-change-this-to-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== MongoDB Configuration =====
# REQUIRED for multi-user mode
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/
MONGODB_DATABASE_NAME=visionguard_ai

# For MongoDB Atlas (cloud):
# MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== Optional: Telegram Bot (per-user, configured in profile) =====
# Users will configure their own Telegram bots in the application

# ===== Optional: Gemini API (for deepfake detection) =====
# GEMINI_API_KEY=your-gemini-api-key-here

# ===== Security Note =====
# NEVER commit the .env file to version control!
# The .env file is already in .gitignore
